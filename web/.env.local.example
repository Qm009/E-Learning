# ============================================================
# EduFlow Web — Variables d'environnement (EXEMPLE)
# Copiez ce fichier en .env.local et remplissez les valeurs
# ============================================================

# --- SUPABASE (OBLIGATOIRE) ---
# Trouvez ces valeurs dans : Supabase Dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# --- GOOGLE GEMINI AI (pour la génération de quiz) ---
# Créez votre clé sur : https://aistudio.google.com/app/apikey
# Si non fournie, le mode DÉMO est activé automatiquement (données fictives)
GEMINI_API_KEY=your-gemini-api-key-here

# --- OPENAI (pour generate-quiz Edge Function Supabase) ---
# Non obligatoire si vous utilisez uniquement Gemini via l'API Next.js
# OPENAI_API_KEY=your-openai-api-key-here
